# ============================================================================
# ForkCV — environment variables
#
# Copy this file to `.env.local` and fill in your OpenAI key.
# NEVER commit a real `.env*` file. Only `.env.example` is tracked in git.
# ============================================================================

# --- OpenAI -----------------------------------------------------------------
# Used by JD analyzer, selector, skills enricher, summary rewriter, ingest.
# Get a key at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# --- Hunter.io (optional, for the Outreach feature) -------------------------
# Used to find ~10 ranked contacts per job (recruiters / hiring managers /
# team ICs) + their LinkedIn URLs + emails. Hunter's free tier includes API
# access: 25 domain searches/mo + 50 verifications/mo, no per-credit billing.
# Sign up at https://hunter.io and grab a key at https://hunter.io/api-keys
# Leave blank to disable the Outreach panel; the rest of ForkCV works fine
# without it.
HUNTER_API_KEY=
