# ============================================================================
# ForkCV — environment variables
#
# Copy this file to `.env.local` and fill in your OpenAI key.
# NEVER commit a real `.env*` file. Only `.env.example` is tracked in git.
# ============================================================================

# --- OpenAI -----------------------------------------------------------------
# Used by JD analyzer, selector, skills enricher, summary rewriter, ingest.
# Get a key at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# --- Job discovery backend --------------------------------------------------
# Default: 'jobspy' — free, uses the python-jobspy library to scrape
# LinkedIn / Indeed / Google Jobs directly. No API key. Most LinkedIn
# free-trial Apify actors expire after the first run, so jobspy is the
# practical default.
# Set DISCOVERY_BACKEND=apify if you've rented an Apify LinkedIn actor.
DISCOVERY_BACKEND=jobspy

# Jobspy-specific:
# Comma-separated sites to scrape. Options: indeed, linkedin, glassdoor,
# google, zip_recruiter. LinkedIn is rate-limited hardest; Indeed + Google
# are most reliable.
JOBSPY_SITES=indeed,linkedin,google
JOBSPY_COUNTRY_INDEED=USA

# Apify (only used if DISCOVERY_BACKEND=apify):
APIFY_API_TOKEN=
# APIFY_ACTOR_ID=bebity~linkedin-jobs-scraper


# --- Google Sheets sync (optional) ------------------------------------------
# Service-account auth (no OAuth dance). See src/sheets_sync.py for the 5-min
# GCP setup walkthrough. Leave blank to disable Sheets sync; discovery still
# runs and persists locally.
GOOGLE_SERVICE_ACCOUNT_JSON=
SHEETS_SPREADSHEET_ID=
SHEETS_RANGE=Sheet1!A1

# --- Hunter.io (optional, for the Outreach feature) -------------------------
# Used to find ~10 ranked contacts per job (recruiters / hiring managers /
# team ICs) + their LinkedIn URLs + emails. Hunter's free tier includes API
# access: 25 domain searches/mo + 50 verifications/mo, no per-credit billing.
# Sign up at https://hunter.io and grab a key at https://hunter.io/api-keys
# Leave blank to disable the Outreach panel; the rest of ForkCV works fine
# without it.
HUNTER_API_KEY=
